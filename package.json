{
  "name": "@hritikwork.npm/favicon-kit",
  "version": "0.2.0",
  "description": "Generate favicon assets, head snippets, and runtime favicon injection helpers.",
  "keywords": [
    "favicon",
    "icon",
    "ico",
    "apple-touch-icon",
    "laravel",
    "hugo",
    "html"
  ],
  "license": "MIT",
  "author": {
    "name": "hritikwork24",
    "email": "hritikwork.dev@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hritikwork24/favicon-kit.git"
  },
  "bugs": {
    "url": "https://github.com/hritikwork24/favicon-kit/issues"
  },
  "homepage": "https://github.com/hritikwork24/favicon-kit#readme",
  "type": "module",
  "sideEffects": false,
  "bin": "./src/cli.js",
  "exports": {
    ".": "./src/index.js",
    "./node": "./src/node.js",
    "./browser": "./src/browser.js",
    "./adapters/html": "./src/adapters/html.js",
    "./adapters/laravel": "./src/adapters/laravel.js",
    "./adapters/hugo": "./src/adapters/hugo.js",
    "./cli": "./src/cli.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node ./test/run-tests.js",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm test && npm run pack:check"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "png-to-ico": "^2.1.8",
    "sharp": "^0.33.5"
  }
}
